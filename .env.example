# TTS provider selection
# edge works without API keys and is the default public-friendly provider.
TTS_PROVIDER=<edge|local|volcengine|http|none>

# Microsoft Edge online TTS, no API key required
EDGE_TTS_VOICE=<voice-name>
EDGE_TTS_LANG=<language-code>
EDGE_TTS_RATE=<rate>
EDGE_TTS_PITCH=<pitch>
EDGE_TTS_VOLUME=<volume>
EDGE_TTS_TIMEOUT=<milliseconds>
EDGE_TTS_PROXY=

# Local macOS TTS
MACOS_TTS_VOICE=<voice-name>
MACOS_TTS_RATE=<words-per-minute>

# Volcengine / ByteDance TTS
VOLCENGINE_TTS_APPID=
VOLCENGINE_TTS_ACCESS_TOKEN=
VOLCENGINE_TTS_CLUSTER=<cluster>
VOLCENGINE_TTS_VOICE_TYPE=
VOLCENGINE_TTS_PRESET=<preset-id>
VOLCENGINE_TTS_SPEED_RATIO=<speed-ratio>
VOLCENGINE_TTS_LOUDNESS_RATIO=<loudness-ratio>
VOLCENGINE_TTS_MODEL=<model-name>

# Generic HTTP TTS adapter
TTS_API_BASE_URL=
TTS_API_KEY=
TTS_API_AUTH_TYPE=<bearer|header|none>
TTS_API_KEY_HEADER=<header-name>
TTS_API_MODEL=
TTS_API_VOICE=
TTS_API_FORMAT=<audio-format>
TTS_API_METHOD=<http-method>
TTS_API_SPEED=<speed>
TTS_API_VOICES_URL=
TTS_API_APP_ID=
TTS_API_APP_SECRET=
TTS_API_BASE_ID=
TTS_API_EXTRA_JSON=
